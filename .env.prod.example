# Prod runtime secrets — copy to project root as `.env` (never commit .env)
#
#   cp .env.prod.example .env
#   nano .env
#   docker compose -f compose.prod.yml pull
#   docker compose -f compose.prod.yml up -d
#
# compose.prod.yml reads JWT_SECRET from this file.
# DB_* below are optional overrides; defaults are in compose.prod.yml (postgres service).

JWT_SECRET=change-me-to-a-random-string-at-least-48-characters-long
