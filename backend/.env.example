DB_HOST=192.168.22.111
DB_PORT=5432
DB_NAME=moca-test-db
DB_USER=duylong
DB_PASSWORD=duylongadminpass
SERVER_PORT=8080

# JWT signing key — HS384 needs ≥48 characters. Use same value across deploys.
JWT_SECRET=change-me-to-a-random-string-at-least-48-chars-long

# PostgreSQL admin UI (pgAdmin): http://192.168.22.111/browser/
# Database name on server "DuyLong": moca-test-db

# MinIO — set MINIO_ENABLED=true when object-storage host is ready
MINIO_ENABLED=false
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=moca-drawings
MINIO_AUTO_CREATE_BUCKET=false

# Redis — remote cache (https://redis.duylong.art/ is web UI; app uses redis:// host:6379)
REDIS_ENABLED=true
REDIS_HOST=redis.duylong.art
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_SSL=true

# Hikari (prod profile) — optional overrides for application-prod.yml
# HIKARI_MAX_POOL_SIZE=20
# HIKARI_MIN_IDLE=5
# HIKARI_CONNECTION_TIMEOUT=30000
# HIKARI_IDLE_TIMEOUT=600000
# HIKARI_MAX_LIFETIME=1800000
